# Gopal Trading Company - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/gopal_trading
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/gopal_trading

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry
JWT_EXPIRES_IN=7d

# Admin credentials (used to seed first admin account)
ADMIN_EMAIL=admin@gopaltrading.com
ADMIN_PASSWORD=Admin@1234

# Email (Nodemailer - optional for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Gopal Trading <noreply@gopaltrading.com>

# WhatsApp (Twilio - optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
